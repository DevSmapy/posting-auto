# --- Compose ---
# 한글/공백 경로에서도 Compose가 동작하도록 프로젝트명 고정
COMPOSE_PROJECT_NAME=posting-auto

# --- n8n ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul

# --- 스토리지 배치 ---
# WD_BLACK (HDD): ollama 제외 이미지·n8n·postgres 데이터
# Extreme SSD: ollama 이미지·모델 데이터 (용량·속도)
IMAGE_DIR=/Volumes/WD_BLACK/Careers/DockerData/images
POSTGRES_DATA_PATH=/Volumes/WD_BLACK/Careers/DockerData/posting-auto/postgres
N8N_DATA_PATH=/Volumes/WD_BLACK/Careers/DockerData/n8n_data
# 경로에 공백이 있으므로 반드시 따옴표 사용 (bash source / 일부 툴 호환)
OLLAMA_IMAGE_DIR="/Volumes/Extreme SSD/DockerData/images"
OLLAMA_DATA_PATH="/Volumes/Extreme SSD/DockerData/ollama_data"

# --- Postgres (호스트 5433 — 기존 DB와 충돌 방지) ---
POSTGRES_HOST=127.0.0.1
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n
POSTGRES_PORT=5433
# optional: postgresql://n8n:change_me@127.0.0.1:5433/n8n
DATABASE_URL=
# auto | postgres | sqlite  (postgres 실패 시 sqlite fallback)
SEEN_URLS_BACKEND=auto
SEEN_URLS_SQLITE=./output/seen_urls.sqlite

# --- Ollama (run_draft.sh가 컨테이너 start/stop 관리) ---
# Compose/다른 컨테이너 → host.docker.internal
# 호스트 스크립트(mvp_pipeline, smoke) → OLLAMA_HOST_URL
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HOST_URL=http://127.0.0.1:11434
OLLAMA_PORT=11434
OLLAMA_CONTAINER=ollama
OLLAMA_MODEL=qwen2.5:7b
# 권장(한글): qwen2.5:7b — curl -N http://127.0.0.1:11434/api/pull -d '{"name":"qwen2.5:7b"}'
OLLAMA_TIMEOUT_MS=300000
# 브리핑 JSON은 더 길 수 있음 (미설정 시 OLLAMA_TIMEOUT_MS, 둘 다 없으면 600000)
OLLAMA_BRIEFING_TIMEOUT_MS=600000
# 잡 중 모델 유지; run_draft 종료 시 ollama stop으로 unload
OLLAMA_KEEP_ALIVE=30m
# run_draft.sh: 1이면 start→작업→stop (기본 1). 메모리 꼬이면 OLLAMA_DOCKER_RESTART=1
OLLAMA_AUTO_CONTAINER=1
OLLAMA_DOCKER_RESTART=0
# docker update 한도 (Desktop RAM과 별개) — ./scripts/limit_ollama_resources.sh
OLLAMA_DOCKER_CPUS=4.0
OLLAMA_DOCKER_MEMORY=10g
# MacBook Air 등: CPU 폭주 완화
OLLAMA_NUM_THREAD=4
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.3
# llm | heuristic — 아침 cron은 heuristic 권장(브리핑 LLM 1회에 예산 집중)
RANK_MODE=heuristic
# heuristic 점수 이 값 이상만 기사별 LLM 중요도 호출
HEURISTIC_MIN_SCORE=8
# 임계값 통과분 중 LLM에 넣을 최대 건수 (heuristic 상위부터)
NEWS_LLM_CANDIDATES=10
# llm | heuristic
BRIEFING_MODE=llm
ALLOW_BRIEFING_FALLBACK=1

# --- Google News ---
GNEWS_BUSINESS_RSS=https://news.google.com/rss/headlines/section/topic/BUSINESS?hl=ko&gl=KR&ceid=KR:ko
GNEWS_NATION_RSS=https://news.google.com/rss/headlines/section/topic/NATION?hl=ko&gl=KR&ceid=KR:ko
NEWS_TIMEZONE=Asia/Seoul
# since_prev_day_hour | today
NEWS_WINDOW_MODE=since_prev_day_hour
# 전일 이 시각(KST)부터 실행 시각까지 포함 (장후~아침 브리핑)
NEWS_WINDOW_PREV_DAY_HOUR=15
NEWS_MAX_CANDIDATES=12
NEWS_PICK_COUNT=5
WATCHLIST=금리,환율,연준,반도체,삼성전자,부동산,고용

# --- Instagram / Meta (후속 옵션; 반자동 블로그 발행에는 불필요) ---
IG_USER_ID=
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v21.0
# 1이면 Approve 후 카드렌더/인스타까지 시도 (기본 0 = 마크다운만)
PUBLISH_CARDS=0
CARD_BRAND=경제 브리핑

# --- Notify / Approve 채널 ---
# discord | telegram | cli | auto
# 미설정 시: Discord 토큰 있으면 discord → 없으면 telegram → 없으면 cli
NOTIFY_CHANNEL=
# draft 모드: 브리핑 준비 후 이 시각(Asia/Seoul HH:MM)에 Approve 초안 발송
# 비우면 준비 즉시 발송. 이미 지난 시각이면 대기 없이 즉시 발송
NOTIFY_SEND_AT=07:50
# Approve 대기 초 (Discord/Telegram 공통, 기본 15분)
APPROVE_TIMEOUT_SEC=900

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# (호환) TELEGRAM_APPROVE_MODE=telegram|cli|auto — NOTIFY_CHANNEL 우선
TELEGRAM_APPROVE_MODE=
TELEGRAM_APPROVE_TIMEOUT_SEC=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=posting-cards
R2_PUBLIC_BASE_URL=https://your-public-base.example
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

# --- Browserless ---
BROWSERLESS_URL=http://localhost:3000
CARD_WIDTH=1080
CARD_HEIGHT=1080

# --- MVP 파이프라인 옵션 ---
# dry_run | draft (Approve→마크다운 저장) | publish (Approve 없이 마크다운 저장)
MVP_MODE=dry_run
OUTPUT_DIR=./output
